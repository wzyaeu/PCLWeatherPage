<Grid Margin="5">
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="auto"/>
        <ColumnDefinition Width="auto"/>
        <ColumnDefinition Width="1*"/>
    </Grid.ColumnDefinitions>
    <TextBlock FontSize="17"
               FontWeight="Bold"
               Foreground="{DynamicResource ColorBrush3}"
               Text="实时天气"/>
    <TextBlock FontSize="12"
               VerticalAlignment="Bottom"
               Margin="2,0,0,0"
               Grid.Column="1"
               Foreground="{DynamicResource ColorBrush4}"
               Text="数据更新于 {nowweather-time}"/>
    <Line X1="0"
          Grid.Column="2"
          Y1="0"
          X2="1000"
          Y2="0"
          StrokeThickness="2"
          VerticalAlignment="Center"
          Stroke="{DynamicResource ColorBrush3}"
          Margin="10,0"/>
</Grid>
<local:MyCard Margin="0,5">
    <StackPanel>
        <Grid Margin="10,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Grid
                Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="1*"
                                      MinWidth="210"/>
                </Grid.ColumnDefinitions>
                <StackPanel Margin="3"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                    <StackPanel
                        Grid.Column="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontSize="63"
                                       FontFamily="Arial"
                                       Foreground="{DynamicResource ColorBrush3}"
                                       FontWeight="Bold"
                                       Text="{nowweather-temp}℃"/>
                            <Path
                                Width="55"
                                VerticalAlignment="Center"
                                Height="55"
                                Stretch="Uniform"
                                Fill="{DynamicResource ColorBrush3}"
                                Data="{nowweather-weathericon}"/>
                        </StackPanel>
                        <TextBlock FontSize="18"
                                   Foreground="{DynamicResource ColorBrush4}"
                                   HorizontalAlignment="Center"
                                   Text="体感 {nowweather-feeltemp}℃ / {nowweather-weather}"/>
                    </StackPanel>
                </StackPanel>
                <Grid 
                      Grid.Column="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="10*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="10*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="10*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="1*"/>
                    </Grid.RowDefinitions>
                    <StackPanel
                        Grid.Column="1"
                        Grid.Row="1">
                        <TextBlock FontSize="13"
                                   Foreground="{DynamicResource ColorBrush4}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Text="风向"
                                   Margin="2"/>
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <TextBlock FontSize="20"
                                       Foreground="{DynamicResource ColorBrush3}"
                                       Text="{nowweather-winddir}"/>
                            <TextBlock FontSize="12"
                                       Foreground="{DynamicResource ColorBrush4}"
                                       Text="风"
                                       VerticalAlignment="Bottom"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel
                        Grid.Column="3"
                        Grid.Row="1">
                        <TextBlock FontSize="13"
                                   Foreground="{DynamicResource ColorBrush4}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Text="风力"
                                   Margin="2"/>
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                            <TextBlock FontSize="20"
                                       Foreground="{DynamicResource ColorBrush3}"
                                       Text="{nowweather-windscale}"/>
                            <TextBlock FontSize="12"
                                       Foreground="{DynamicResource ColorBrush4}"
                                       Text="级"
                                       VerticalAlignment="Bottom"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel
                        Grid.Column="5"
                        Grid.Row="1">
                        <TextBlock FontSize="13"
                                   Foreground="{DynamicResource ColorBrush4}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Text="风速"
                                   Margin="2"/>
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                            <TextBlock FontSize="20"
                                       Foreground="{DynamicResource ColorBrush3}"
                                       Text="{nowweather-windspeed}"/>
                            <TextBlock FontSize="12"
                                       Foreground="{DynamicResource ColorBrush4}"
                                       Text="km/h"
                                       VerticalAlignment="Bottom"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel
                        Grid.Column="1"
                        Grid.Row="2">
                        <TextBlock FontSize="13"
                                   Foreground="{DynamicResource ColorBrush4}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Text="湿度"
                                   Margin="2"/>
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                            <TextBlock FontSize="20"
                                       Foreground="{DynamicResource ColorBrush3}"
                                       Text="{nowweather-humidity}"/>
                            <TextBlock FontSize="12"
                                       Foreground="{DynamicResource ColorBrush4}"
                                       Text="%"
                                       VerticalAlignment="Bottom"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel
                        Grid.Column="3"
                        Grid.Row="2"
                        ToolTip="过去1个小时的降水量">
                        <TextBlock FontSize="13"
                                   Foreground="{DynamicResource ColorBrush4}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Text="降水量"
                                   Margin="2"/>
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                            <TextBlock FontSize="20"
                                       Foreground="{DynamicResource ColorBrush3}"
                                       Text="{nowweather-precip}"/>
                            <TextBlock FontSize="12"
                                       Foreground="{DynamicResource ColorBrush4}"
                                       Text="mm"
                                       VerticalAlignment="Bottom"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel
                        Grid.Column="5"
                        Grid.Row="2">
                        <TextBlock FontSize="13"
                                   Foreground="{DynamicResource ColorBrush4}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Text="云量"
                                   Margin="2"/>
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                            <TextBlock FontSize="20"
                                       Foreground="{DynamicResource ColorBrush3}"
                                       Text="{nowweather-cloud}"/>
                            <TextBlock FontSize="12"
                                       Foreground="{DynamicResource ColorBrush4}"
                                       Text="%"
                                       VerticalAlignment="Bottom"/>
                        </StackPanel>

                    </StackPanel>
                    <StackPanel
                        Grid.Column="1"
                        Grid.Row="3">
                        <TextBlock FontSize="13"
                                   Foreground="{DynamicResource ColorBrush4}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Text="能见度"
                                   Margin="2"/>
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                            <TextBlock FontSize="20"
                                       Foreground="{DynamicResource ColorBrush3}"
                                       Text="{nowweather-vis}"/>
                            <TextBlock FontSize="12"
                                       Foreground="{DynamicResource ColorBrush4}"
                                       Text="km"
                                       VerticalAlignment="Bottom"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel
                        Grid.Column="3"
                        Grid.Row="3">
                        <TextBlock FontSize="13"
                                   Foreground="{DynamicResource ColorBrush4}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Text="大气压强"
                                   Margin="2"/>
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                            <TextBlock FontSize="20"
                                       Foreground="{DynamicResource ColorBrush3}"
                                       Text="{nowweather-pressure}"/>
                            <TextBlock FontSize="12"
                                       Foreground="{DynamicResource ColorBrush4}"
                                       Text="hPa"
                                       VerticalAlignment="Bottom"/>
                        </StackPanel>

                    </StackPanel>
                    <StackPanel
                        Grid.Column="5"
                        Grid.Row="3">
                        <TextBlock FontSize="13"
                                   Foreground="{DynamicResource ColorBrush4}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Text="露点温度"
                                   Margin="2"/>
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                            <TextBlock FontSize="20"
                                       Foreground="{DynamicResource ColorBrush3}"
                                       Text="{nowweather-dew}"/>
                            <TextBlock FontSize="12"
                                       Foreground="{DynamicResource ColorBrush4}"
                                       Text="℃"
                                       VerticalAlignment="Bottom"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </StackPanel>
</local:MyCard>
<Grid Margin="5">
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="auto"/>
        <ColumnDefinition Width="auto"/>
        <ColumnDefinition Width="1*"/>
    </Grid.ColumnDefinitions>
    <TextBlock FontSize="17"
               FontWeight="Bold"
               Foreground="{DynamicResource ColorBrush3}"
               Text="未来天气"/>
    <TextBlock FontSize="12"
               VerticalAlignment="Bottom"
               Margin="2,0,0,0"
               Grid.Column="1"
               Foreground="{DynamicResource ColorBrush4}"
               Text="数据更新于 {futweather-time}"/>
    <Line X1="0"
          Grid.Column="2"
          Y1="0"
          X2="1000"
          Y2="0"
          StrokeThickness="2"
          VerticalAlignment="Center"
          Stroke="{DynamicResource ColorBrush3}"
          Margin="10,0"/>
</Grid>
<local:MyCard Margin="0,5">
    <StackPanel Margin="10">
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto" Height="130">
            <StackPanel
                HorizontalAlignment="Center">
                {futweather-items}
            </StackPanel>
        </ScrollViewer>
    </StackPanel>
</local:MyCard>
<Grid Margin="5">
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="auto"/>
        <ColumnDefinition Width="1*"/>
    </Grid.ColumnDefinitions>
    <TextBlock FontSize="17"
               FontWeight="Bold"
               Foreground="{DynamicResource ColorBrush3}"
               Text="关于主页"/>
    <Line X1="0"
          Grid.Column="1"
          Y1="0"
          X2="1000"
          Y2="0"
          StrokeThickness="2"
          VerticalAlignment="Center"
          Stroke="{DynamicResource ColorBrush3}"
          Margin="10,0"/>
</Grid>
<local:MyCard Margin="0,5">
    <StackPanel>
        <Border Background="{DynamicResource ColorBrush4}"
                CornerRadius="5,5,0,0"
                Height="100">
            <StackPanel Margin="16"
                        HorizontalAlignment="Center">
                <TextBlock FontSize="32"
                           Foreground="{DynamicResource ColorBrush7}"
                           Text="Weather 天气预报"
