<Grid Margin="5">
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="auto"/>
        <ColumnDefinition Width="1*"/>
    </Grid.ColumnDefinitions>
    <TextBlock FontSize="17"
               FontWeight="Bold"
               Foreground="{DynamicResource ColorBrush3}"
               Text="错误"/>
    <Line X1="0"
          Grid.Column="2"
          Y1="0"
          X2="1000"
          Y2="0"
          StrokeThickness="2"
          VerticalAlignment="Center"
          Stroke="{DynamicResource ColorBrush3}"
          Margin="10,0"/>
</Grid>
<local:MyCard Margin="0,5">
    <StackPanel Margin="15">
        <TextBlock FontSize="13"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource ColorBrush3}"
                   Text="{text}"/>
        {data}
    </StackPanel>
</local:MyCard>